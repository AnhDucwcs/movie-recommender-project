TMDB_API_KEY=your_api_key_here

# Đường dẫn thư mục data (tương đối từ thư mục backend/)
# Giữ nguyên giá trị này khi chạy local, Docker tự override qua docker-compose.yml
DATA_DIR=../data

# Cấu hình trending từ ratings.csv
# Để rỗng để tự dùng: {DATA_DIR}/raw/ml-latest-small/ratings.csv
RATINGS_CSV_PATH=
TRENDING_DEFAULT_LIMIT=20
TRENDING_MAX_LIMIT=50
TRENDING_MIN_VOTES=0

# Database (local fallback)
# Local dev nhanh: để mặc định SQLite
# Nếu dùng Postgres local thì đổi sang:
# DATABASE_URL=postgresql+psycopg2://movieapp:movieapp@localhost:5432/movie_recommender
DATABASE_URL=sqlite:///./movie_recommender.db
DB_ECHO=false