# =========================
# Frontend .gitignore
# Stack: Next.js + TypeScript
# =========================

# Node dependencies
node_modules/

# Package manager internals
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build outputs
.next/
out/
build/

# Tooling caches
.turbo/
.cache/
.eslintcache

# Test outputs
coverage/
playwright-report/
test-results/

# Runtime logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# Deployment
.vercel/

# TypeScript incremental build cache
*.tsbuildinfo

# Editor and OS files
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Certificates and local secrets
*.pem
